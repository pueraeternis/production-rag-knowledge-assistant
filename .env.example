LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=local
LLM_MODEL=Qwen/Qwen3.6-35B-A3B
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=120

# Dense embedding runtime (Plan 16) — default stub for CI
RAG_EMBEDDING_MODE=stub
RAG_EMBEDDING_MODEL=BAAI/bge-m3
RAG_EMBEDDING_DEVICE=cpu
RAG_EMBEDDING_BATCH_SIZE=32
RAG_EMBEDDING_MAX_LENGTH=8192
RAG_EMBEDDING_NORMALIZE=true

# Reranker runtime (Plan 17) — default stub for CI
RAG_RERANKER_MODE=stub
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RAG_RERANKER_DEVICE=auto
RAG_RERANKER_BATCH_SIZE=16
RAG_RERANKER_MAX_LENGTH=1024
RAG_RERANKER_USE_FP16=false

# Optional real-model smoke tests (skipped by default in CI)
# RAG_EMBEDDING_ENABLE_REAL_TESTS=false
# RAG_RERANKER_ENABLE_REAL_TESTS=false
